{
  "name": "@sequa/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sequa source agent — deterministic MA-crossover strategy core + Claude-narrated per-signal thesis (Phase 1).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "eval:unit": "vitest run eval/",
    "eval:prompt": "promptfoo eval -c eval/promptfooconfig.yaml --no-progress-bar",
    "eval:ci": "vitest run eval/ && promptfoo eval -c eval/promptfooconfig.yaml --no-cache --share=false"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.104.1",
    "dotenv": "^16.6.1",
    "viem": "^2.52.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "promptfoo": "^0.118.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
