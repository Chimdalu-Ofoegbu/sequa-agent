# Sequa source agent — runtime secrets. Copy to .env (gitignored) and fill.
# NEVER commit the real .env (D-26/D-42).

# Anthropic Messages API key — read by the narration client singleton.
# Only required to run the live agent / eval:prompt. eval:unit runs offline with no key.
ANTHROPIC_API_KEY=

# Operator EOA private key — holds capital + gas, registers the source, signs recordSignal + swaps (D-26).
# Required to run the poll loop (npm run agent) and the reconciler (npm run reconcile).
OPERATOR_PRIVATE_KEY=

# GitHub PAT (fine-scoped: single repo, contents-write) — the runtime pushes the off-chain thesis JSON
# theses/<agentId>/<signalId>.json via this token (D-37). Optional: if unset, theses are written to
# disk but not git-pushed. Set THESIS_GIT_REMOTE to a PAT-embeddable https remote to push to a
# dedicated repo; otherwise the ambient credential helper / default remote is used.
GITHUB_PAT=
# THESIS_GIT_REMOTE=https://github.com/<owner>/<repo>.git
# THESIS_GIT_PUSH=true   # set to false to disable git pushing even with a PAT present

# Noise bot EOA private key — a SEPARATE key from the operator (D-24). The ambient noise bot
# (npm run noise) does random small swaps to keep the momentum MAs crossing; its swaps are NOT part
# of the agent's track record. Added at hosting time (Plan 06). Only the noise bot reads this.
NOISE_BOT_PRIVATE_KEY=

# /healthz HTTP port (D-38). Defaults to 8080 if unset.
# HEALTH_PORT=8080

# Reconciler block-range floor (defaults to 0 = genesis). Set to the SourceRegistry deploy block to
# narrow the getLogs window once known (Plan 06).
# RECONCILE_FROM_BLOCK=0
